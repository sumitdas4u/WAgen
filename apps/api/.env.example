NODE_ENV=production
PORT=4000
APP_BASE_URL=https://wagenai.com
JWT_SECRET=replace_with_a_long_random_secret
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/typo
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=0
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=wagenai
FIREBASE_CLIENT_EMAIL=your_service_account_email@wagenai.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
REDIS_URL=redis://redis:6379
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-this-password
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret
RAZORPAY_PLAN_STARTER_ID=plan_xxxxx_starter
RAZORPAY_PLAN_PRO_ID=plan_xxxxx_pro
RAZORPAY_PLAN_BUSINESS_ID=plan_xxxxx_business
TRIAL_DAYS=14
TRIAL_CREDITS=200
CONVERSATION_WINDOW_HOURS=24
LOW_CREDIT_THRESHOLD=10
CREDIT_RENEWAL_CRON_ENABLED=true
CREDIT_RENEWAL_CRON_INTERVAL_SECONDS=86400
DASHBOARD_BILLING_CENTER=true
DASHBOARD_FEATURE_FLAGS={}
BILLING_GST_RATE_PERCENT=18
RECHARGE_PRICE_PER_1000_CREDITS_INR=5000
AUTO_RECHARGE_CRON_ENABLED=true
AUTO_RECHARGE_CRON_INTERVAL_SECONDS=300
AUTO_RECHARGE_MAX_FAILURES=3
AUTO_RECHARGE_SWEEP_LIMIT=200
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_EMBEDDED_SIGNUP_CONFIG_ID=your_embedded_signup_config_id
META_VERIFY_TOKEN=replace_with_meta_webhook_verify_token
META_REDIRECT_URI=https://wagenai.com/meta-callback
META_PHONE_REGISTRATION_PIN=123456
META_GRAPH_VERSION=v25.0
META_STATUS_SYNC_INTERVAL_SECONDS=300
META_TOKEN_ENCRYPTION_KEY=f8Kx9LmQ2vTz7RjYp4NcW6sDh3UbXa1E
META_SYSTEM_USER_TOKEN=
META_PARTNER_BUSINESS_ID=
META_SHARED_BILLING_REQUIRED=false
META_SHARED_BILLING_CURRENCY=INR
WA_SESSION_ENCRYPTION_KEY=J4s9Ld2Qx7Vt3Yh8Pr6Nc1Wm5Kb0XeAz
USD_TO_INR=83
OPENAI_MAX_OUTPUT_TOKENS=220
OPENAI_LOG_USAGE=true
PROMPT_HISTORY_LIMIT=6
RAG_RETRIEVAL_LIMIT=8
RAG_MIN_SIMILARITY=0.08
RAG_KNOWLEDGE_ROUTER=true
RAG_MIN_QUERY_LENGTH=12
RAG_MAX_PROMPT_CHARS=3200
INGEST_MAX_SOURCE_CHARS=0
INGEST_MAX_CHUNKS_PER_FILE=0
INGEST_CHUNK_TARGET_TOKENS=650
INGEST_CHUNK_OVERLAP_TOKENS=110
INGEST_EMBED_BATCH_SIZE=24
OPENAI_EMBED_TIMEOUT_MS=45000
PDF_PARSE_TIMEOUT_MS=120000
PDF_UPLOAD_BUFFER_TIMEOUT_MS=45000
PDF_MIN_TEXT_CHARS=1
INBOUND_MEDIA_MAX_BYTES=8388608
INBOUND_MEDIA_TIMEOUT_MS=45000
INBOUND_MEDIA_MAX_TEXT_CHARS=2200
BOT_LOOP_DETECTION_ENABLED=true
BOT_LOOP_QUICK_REPLY_SECONDS=8
BOT_LOOP_REPEAT_WINDOW_SECONDS=180
BOT_LOOP_DETECTION_KEYWORDS=automated,auto-reply,auto reply,do not reply,this is an automated message,virtual assistant,chatbot,bot
REPLY_DELAY_MIN_MS=2000
REPLY_DELAY_MAX_MS=5000
CONTACT_COOLDOWN_SECONDS=0
AUTO_RECONNECT=true

# Google OAuth
# Setup steps:
# 1. https://console.cloud.google.com -> APIs & Services -> Credentials
# 2. Create OAuth 2.0 Client ID (type: Web application)
# 3. Authorized redirect URIs:
#    - https://wagenai.com/api/google/sheets/connect/callback
#    - https://wagenai.com/api/google/calendar/connect/callback
#    - https://wagenai.com/api/auth/google/callback
# 4. Enable: Google Sheets API + Google Drive API + Google Calendar API
GOOGLE_SHEETS_CLIENT_ID=your_google_oauth_client_id
GOOGLE_SHEETS_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_SHEETS_OAUTH_REDIRECT_URI=https://wagenai.com/api/google/sheets/connect/callback
GOOGLE_SHEETS_TOKEN_ENCRYPTION_KEY=replace_with_32_plus_char_random_secret

# Optional Google Calendar override.
# If left empty, Calendar falls back to the Google Sheets OAuth credentials above.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=https://wagenai.com/api/google/calendar/connect/callback
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=
